<% width = local_assigns.fetch(:width, '37').to_s %>
<% height = local_assigns.fetch(:height, '37').to_s %>
<% width = "#{width}px" unless width.end_with?('px', '%', 'rem', 'em') %>
<% height = "#{height}px" unless height.end_with?('px', '%', 'rem', 'em') %>

<img
  src="/docuizzi-mark.png"
  alt="<%= Docuseal.product_name %>"
  class="<%= local_assigns[:class] %>"
  style="width: <%= width %>; height: <%= height %>; object-fit: contain;"
>
